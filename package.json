{
  "name": "@consilioweb/payload-support",
  "version": "0.9.12",
  "description": "Payload CMS plugin — professional support & ticketing system with AI, SLA, time tracking, live chat, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./views": {
      "import": {
        "types": "./dist/views.d.ts",
        "default": "./dist/views.js"
      },
      "require": {
        "types": "./dist/views.d.cts",
        "default": "./dist/views.cjs"
      }
    },
    "./components/TicketConversation": {
      "import": {
        "default": "./dist/components/TicketConversation/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "payload",
    "payload-cms",
    "payload-plugin",
    "support",
    "ticketing",
    "helpdesk",
    "customer-support",
    "sla",
    "time-tracking",
    "live-chat",
    "ai",
    "csat",
    "knowledge-base",
    "webhooks",
    "email-tracking",
    "canned-responses",
    "macros",
    "round-robin",
    "crm",
    "i18n",
    "nextjs",
    "react",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pOwn3d/payload-support.git"
  },
  "homepage": "https://github.com/pOwn3d/payload-support#readme",
  "bugs": {
    "url": "https://github.com/pOwn3d/payload-support/issues"
  },
  "author": "ConsilioWEB <contact@consilioweb.fr> (https://consilioweb.fr)",
  "license": "MIT",
  "peerDependencies": {
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/translations": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": ">=0.300.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/ui": {
      "optional": true
    },
    "@payloadcms/translations": {
      "optional": true
    },
    "@payloadcms/next": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@payloadcms/next": "^3.77.0",
    "@payloadcms/translations": "^3.77.0",
    "@payloadcms/ui": "^3.77.0",
    "@types/react": "^19.0.0",
    "esbuild-sass-plugin": "^3.7.0",
    "next": "^15.5.14",
    "payload": "^3.77.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
